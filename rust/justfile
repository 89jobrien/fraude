default:
    @just --list

# ── Formatting ──────────────────────────────────────────────────────────────

fmt:
    cargo fmt --all

fmt-check:
    cargo fmt --all --check

# ── Linting ─────────────────────────────────────────────────────────────────

lint:
    cargo clippy --workspace --all-targets -- -D warnings

# ── Build ───────────────────────────────────────────────────────────────────

build:
    cargo build --release -p fraude-cli

# ── Tests ───────────────────────────────────────────────────────────────────

test:
    cargo nextest run --workspace

# ── Gate ────────────────────────────────────────────────────────────────────

# fmt-check + lint + test
ci:
    just fmt-check
    just lint
    just test
